2.CHECK WHETHER THE NUM IS PRIME OR NOT
def is_prime(n):
    if n <= 1:
        return False
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return False
    return True
print(is_prime(7))  

Output: True

3.FIBBONACCI SERIES
def fibonacci(n):
    a, b = 0, 1
    for _ in range(n):
        print(a, end=" ")
        a, b = b, a + b
fibonacci(5)  

Output: 0 1 1 2 3

