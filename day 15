3.FIND LCM OF TWO NUMBERS
a = int(input("Enter first number: "))
b = int(input("Enter second number: "))

if a > b:
    greater = a
else:
    greater = b

while True:
    if greater % a == 0 and greater % b == 0:
        lcm = greater
        break
    greater += 1

print("LCM =", lcm)

OUTPUT
  Enter first number: 6
  Enter second number: 8
  LCM = 24


