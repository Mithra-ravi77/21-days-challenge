1. CHECK AMSTRONG NUMBER
  num = int(input("Enter a number: "))
temp = num
sum = 0

while num > 0:
    digit = num % 10
    sum = sum + digit**3
    num = num // 10

if temp == sum:
    print("Armstrong Number")
else:
    print("Not an Armstrong Number")

  OUTPUT
Enter a number: 27
Not an Armstrong Number

